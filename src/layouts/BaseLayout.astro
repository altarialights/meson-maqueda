---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { restaurant } from '../data/restaurant';
interface Props { title?: string; description?: string; darkHeader?: boolean; }
const { title = 'Mesón Castellano Maqueda | Cocina tradicional en Toledo', description = restaurant.description, darkHeader = false } = Astro.props;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : undefined;
const socialImage = Astro.site ? new URL('/images/logo/meson-castellano-logo.png', Astro.site) : '/images/logo/meson-castellano-logo.png';
const schema = {
  '@context': 'https://schema.org', '@type': 'Restaurant', name: restaurant.name,
  foundingDate: restaurant.foundingYear, telephone: restaurant.phoneHref,
  servesCuisine: restaurant.cuisine,
  url: restaurant.website,
  address: { '@type': 'PostalAddress', streetAddress: 'Carretera N-V, km 74', addressLocality: 'Maqueda', addressRegion: 'Toledo', postalCode: '45515', addressCountry: 'ES' },
};
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png?v=2" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png?v=2" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Mesón Castellano" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical && <meta property="og:url" content={canonical} />}
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1083" />
    <meta property="og:image:height" content="236" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Logotipo de Mesón Castellano, casa fundada en 1959" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content="Logotipo de Mesón Castellano, casa fundada en 1959" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <a class="skip-link" href="#contenido">Saltar al contenido</a>
    <Header dark={darkHeader} />
    <main id="contenido"><slot /></main>
    <Footer />
  </body>
</html>
