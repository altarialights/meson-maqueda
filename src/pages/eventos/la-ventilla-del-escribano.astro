---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventHero from '../../components/events/EventHero.astro';
import EventGallery from '../../components/events/EventGallery.astro';
import EventInquiry from '../../components/events/EventInquiry.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import { eventTypes, ventilla } from '../../data/events';
import { restaurant } from '../../data/restaurant';
---
<BaseLayout title="La Ventilla del Escribano | Bodas y eventos en Maqueda" description="Conoce La Ventilla del Escribano, el espacio de celebraciones vinculado a Mesón Castellano en Maqueda.">
  <nav class="breadcrumbs shell" aria-label="Migas de pan"><a href="/">Inicio</a><span aria-hidden="true">/</span><a href="/eventos">Eventos</a><span aria-hidden="true">/</span><span aria-current="page">La Ventilla del Escribano</span></nav>
  <EventHero eyebrow="Bodas y eventos en Maqueda" title="La Ventilla del Escribano" intro={ventilla.relationship} fullscreen primaryLabel="Solicitar información" primaryHref="#consulta" />
  <section class="events-intro section"><div class="shell events-intro__grid"><SectionHeading eyebrow="Mesón Castellano · Maqueda" title="Un lugar pensado para celebrar" /><div><p class="dropcap">{ventilla.description}</p><p>Un espacio cuidado para celebraciones familiares, encuentros privados y eventos de empresa, con propuestas adaptadas a cada ocasión.</p></div></div></section>
  <section class="event-brand-story section section--dark"><div class="shell event-story__grid"><div class="event-story__mark" data-reveal><span>LVE</span></div><div><SectionHeading eyebrow="Una misma forma de entender la mesa" title="La cocina de Mesón Castellano, parte de cada experiencia" /><p>La relación entre ambas marcas nace de una misma manera de recibir: gastronomía, atención y un entorno cuidado para disfrutar de cada encuentro.</p><a class="text-link" href="/carta">Conocer la cocina de la casa <span>→</span></a></div></div></section>
  <section class="event-types section"><div class="shell"><SectionHeading eyebrow="Bodas y eventos en Maqueda" title="Cada ocasión tiene su manera de celebrarse" /><div class="event-type-grid">{eventTypes.map((event, index) => <a href={`/eventos/${event.slug}`} class:list={['event-type-card', `event-type-card--${event.tone}`]}><span>{String(index + 1).padStart(2, '0')}</span><div><p>{event.eyebrow}</p><h2>{event.name}</h2><i>Ver propuesta →</i></div></a>)}</div></div></section>
  <EventGallery title="El ambiente también forma parte del recuerdo." />
  <EventInquiry />
  <script src="../../scripts/animations.ts"></script>
</BaseLayout>
